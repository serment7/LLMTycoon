# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB connection (defaults: mongodb://localhost:27017 / llm-tycoon)
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB="llm-tycoon"

# ---- LLM Provider (#llm-provider-abstraction) ----
# 서버가 호출하는 LLM 공급자를 단일 선택한다(혼용 없음). env 값이 유효하지 않으면
# claude-cli 로 폴백한다.
#
#   claude-cli : 기존 Claude Code CLI(헤드리스 stream-json, MCP 네이티브). CLAUDE_BIN
#                환경변수와 `claude login` 으로 인증된 세션이 필요하다.
#   ollama     : 로컬 Ollama 데몬(OpenAI 호환 function-calling 지원 모델 권장).
#                기본 엔드포인트 http://localhost:11434.
#   vllm       : OpenAI-compatible /v1/chat/completions 를 노출하는 vLLM 서버.
#                LLM_API_KEY 가 있으면 Authorization: Bearer 로 붙는다.
LLM_PROVIDER="claude-cli"
# 프로바이더별 모델명. claude-cli 는 CLI 가 자체적으로 관리하므로 비워 둬도 된다.
# ollama 예: "qwen3.5:9b" / vllm 예: 서버에 등록된 모델 ID.
LLM_MODEL=""
# ollama/vllm 엔드포인트. 비우면 프로바이더별 기본값(ollama=11434, vllm=8000) 사용.
LLM_BASE_URL=""
# vLLM 토큰(Bearer). ollama 는 무시.
LLM_API_KEY=""
# 로컬 모델의 tool-call 루프 상한 — 이 라운드를 넘기면 마지막 assistant 응답을 반환.
LLM_MAX_TOOL_ITERATIONS="10"
# HTTP 요청 타임아웃(ms). 로컬 모델 초기 로드에 시간이 걸리므로 기본 180s.
LLM_REQUEST_TIMEOUT_MS="180000"
# ollama num_ctx 오버라이드(옵션). 비우면 모델 기본값 사용.
LLM_NUM_CTX=""

# ---- Auth Config ----
# DEV_MODE=true → 로그인/회원가입 우회하고 임시 dev 사용자로 접근
DEV_MODE="false"

# ON_PREMISE=true → MongoDB 로컬 회원 DB 사용
# ON_PREMISE=false → GitHub / GitLab OAuth 로그인/회원가입
ON_PREMISE="true"

# OAuth (ON_PREMISE=false 일 때만 사용)
AUTH_PROVIDER="github"              # github | gitlab
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""
OAUTH_REDIRECT_URL="http://localhost:3000/api/auth/callback"

# 세션 비밀키 (배포 전 반드시 교체)
SESSION_SECRET="change-me"
# Git 토큰 암호화 마스터 키 (32바이트 hex)
GIT_TOKEN_ENC_KEY=""

# ---- Git 자동화 브랜치 분기 기본값 ----
# GET /api/projects/:id/git-automation 과 MCP get_git_automation_settings 의 응답에
# 저장 row 가 해당 필드를 모를 때 끼워 넣는 기본값. MCP trigger_git_automation 에서
# branchStrategy / branchName 을 명시하지 않은 호출도 이 값으로 귀결된다.
#
# GIT_AUTO_BRANCH_STRATEGY
#   new     : `git checkout -B <GIT_AUTO_BRANCH_NAME>` 로 새 브랜치를 만들고 커밋/푸시 (기본)
#   current : checkout 단계를 건너뛰고 현재 HEAD 브랜치에 그대로 커밋/푸시
GIT_AUTO_BRANCH_STRATEGY="new"
# GIT_AUTO_BRANCH_NAME: branchStrategy='new' 에서 사용할 브랜치명. 빈 문자열이면
# Project.branchStrategy(per-session 등) 기반 resolveBranch 가 폴백으로 동작한다.
GIT_AUTO_BRANCH_NAME=""

# ---- 웹 검색 어댑터 (지시 #f64dc11e) ----
# 공급자별 API 키. 빈 값이면 해당 공급자는 자동 비활성 — settings.isEnabled()=false.
# 우선순위: preferredProviders 설정이 있으면 그 순서, 없으면 Bing → Brave → DuckDuckGo.
# DuckDuckGo 는 Instant Answer API 라 키가 필요하지 않다.
WEB_SEARCH_BING_API_KEY=""
WEB_SEARCH_BRAVE_API_KEY=""

# ---- 영상 생성 어댑터 (지시 #804155ce) ----
# 공급자별 API 키. 빈 값이면 해당 공급자는 비활성 — pickProvider() 가 건너뛴다.
# 우선순위: settings.preferredProviders → 없으면 Runway → Pika → StabilityVideo.
# 초당 단가 기본값: Runway $0.05/s · Pika $0.03/s · Stability $0.04/s.
VIDEO_RUNWAY_API_KEY=""
VIDEO_PIKA_API_KEY=""
VIDEO_STABILITY_API_KEY=""
